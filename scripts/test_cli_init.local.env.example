# scripts/test_cli_init.local.env
# 复制本文件为 scripts/test_cli_init.local.env，并填写你的本地参数（此文件不提交）。

# 固定测试用户（留空则自动生成）
# TEST_USER=ciinit04200001

# 初始化显示名与密码
TEST_FULL_NAME="CLI Init Flow Test"
TEST_PASSWORD="Test1234!"

# 初始化配置路径（可选，默认 /tmp）
# TEST_CONFIG_PATH=/tmp/clawdhome-init-config.json
# TEST_CONFIG_TEMPLATE=/绝对路径/你的-config.json

# 绑定策略：
# none         不做绑定
# interactive  运行时询问是否飞书/微信绑定
INIT_BIND_MODE=interactive

# 非交互强制绑定开关（0/1）
ENABLE_FEISHU_BIND=0
ENABLE_WEIXIN_BIND=0

# 启动后是否执行 chat 验证（0/1）
VERIFY_CHAT=1
VERIFY_CHAT_MESSAGE="请简短回复：初始化验证成功"
VERIFY_CHAT_SESSION=default
VERIFY_CHAT_TIMEOUT=120

# 是否 full 流程结束后自动清理（0/1）
AUTO_CLEAN=0

# 清理需要的管理员信息（仅在 clean 或 AUTO_CLEAN=1 时使用）
ADMIN_USER=
ADMIN_PW=

