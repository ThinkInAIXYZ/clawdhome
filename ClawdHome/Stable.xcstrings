    "agent.create.form.agent_id.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave empty to auto-generate from name. Only lowercase letters, digits, underscores, and hyphens allowed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "留空则根据名称自动生成。仅限小写字母、数字、下划线和短横线。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "留空則根據名稱自動生成。僅限小寫字母、數字、下劃線和短橫線。"
          }
        }
      }
    },
