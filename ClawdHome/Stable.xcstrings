{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "adoption.error.duplicate_fullname": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Display name “%@” is already in use, please choose another"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示名“%@”已被使用，请换一个名字"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示名“%@”已被使用，請換一個名字"
          }
        }
      }
    },
    "adoption.error.duplicate_username": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Username @%@ already exists, please try another"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户名 @%@ 已存在，请换一个再试"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用者名稱 @%@ 已存在，請換一個再試"
          }
        }
      }
    },
    "adoption.error.empty_fullname": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Display name cannot be empty"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示名不能为空"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示名不能為空"
          }
        }
      }
    },
    "adoption.error.empty_username": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System username cannot be empty"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统用户名不能为空"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統使用者名稱不能為空"
          }
        }
      }
    },
    "adoption.error.invalid_username": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Username can only contain lowercase letters, digits, and underscores, and must start with a letter"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户名只能包含小写字母、数字和下划线，且须以字母开头"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用者名稱只能包含小寫字母、數字和下劃線，且須以字母開頭"
          }
        }
      }
    },
    "agent.create.form.agent_id": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Agent ID"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Agent ID"
          }
        },
        "zh-Hant": {
