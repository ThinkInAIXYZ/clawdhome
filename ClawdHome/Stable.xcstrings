          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Helper 是以 root 运行的后台服务（LaunchDaemon），负责所有特权操作。正常情况下由 launchd 自动管理，无需手动干预。"
