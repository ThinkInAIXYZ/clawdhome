    "hermes.qr_binding.instruction.whatsapp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the button below to run `hermes whatsapp` in terminal. Scan the QR code with WhatsApp on your phone to complete pairing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击下方按钮，终端将运行 hermes whatsapp 并显示二维码，用手机 WhatsApp 扫描即可完成配对。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊下方按鈕，終端將運行 hermes whatsapp 並顯示二維碼，用手機 WhatsApp 掃描即可完成配對。"
          }
        }
      }
    },
    "hermes.qr_binding.instruction.weixin": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the button below to enter `hermes gateway setup` in terminal, choose WeChat platform, then scan QR code to complete iLink login."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击下方按钮，终端将进入 hermes gateway setup 交互界面，选择【微信】平台后扫描二维码完成 iLink 登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊下方按鈕，終端將進入 hermes gateway setup 交互界面，選擇【微信】平台後掃描二維碼完成 iLink 登錄。"
          }
        }
      }
